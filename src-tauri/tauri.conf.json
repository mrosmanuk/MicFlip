{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MicFlip",
  "version": "1.1.0",
  "identifier": "com.mrosmanuk.micflip",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Flip your mic on or off instantly",
    "longDescription": "A lightweight menu bar / tray utility to mute your microphone at the OS level with a global hotkey. Works in any app — Meet, Zoom, Teams."
  }
}
